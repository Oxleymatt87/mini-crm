# Mini CRM Configuration

# Security
JWT_SECRET=change-this-to-a-secure-random-string

# Database (defaults to SQLite)
DATABASE_URL=sqlite:///./crm.db

# Google Maps (optional, for geocoding)
GOOGLE_MAPS_API_KEY=

# QuickBooks Integration
# Get credentials at https://developer.intuit.com
QB_CLIENT_ID=your-quickbooks-client-id
QB_CLIENT_SECRET=your-quickbooks-client-secret
QB_REDIRECT_URI=http://localhost:10000/quickbooks/callback
QB_ENVIRONMENT=sandbox

# Google Drive Integration (for importing contacts)
# Get credentials at https://console.cloud.google.com
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:10000/google/callback
