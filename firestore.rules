rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /items/{doc} {
      allow read, write: if request.auth != null && (request.auth.uid == 'uSOqxJc3BigB2R6SWAaiXrb4sLj1' || true);
    }
    match /movements/{doc} {
      allow read, write: if request.auth != null && request.auth.uid == 'uSOqxJc3BigB2R6SWAaiXrb4sLj1';
    }
    match /users/{doc} {
      allow read, write: if request.auth != null && request.auth.uid == 'uSOqxJc3BigB2R6SWAaiXrb4sLj1';
    }
    match /zones/{doc} {
      allow read, write: if request.auth != null && request.auth.uid == 'uSOqxJc3BigB2R6SWAaiXrb4sLj1';
    }
    match /config/{doc} {
      allow read, write: if request.auth != null && request.auth.uid == 'uSOqxJc3BigB2R6SWAaiXrb4sLj1';
    }
    match /customers/{doc} {
      allow read, write: if request.auth != null && request.auth.uid == 'uSOqxJc3BigB2R6SWAaiXrb4sLj1';
    }
    match /supplier_catalog/{doc} {
      allow read, write: if request.auth != null && request.auth.uid == 'uSOqxJc3BigB2R6SWAaiXrb4sLj1';
    }
    match /orders/{doc} {
      allow read, write: if request.auth != null && request.auth.uid == 'uSOqxJc3BigB2R6SWAaiXrb4sLj1';
    }
    match /invoices/{doc} {
      allow read, write: if request.auth != null && request.auth.uid == 'uSOqxJc3BigB2R6SWAaiXrb4sLj1';
    }
    match /map_notes/{doc} {
      allow read, write: if request.auth != null && request.auth.uid == 'uSOqxJc3BigB2R6SWAaiXrb4sLj1';
    }
    match /portal_access/{doc} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == 'uSOqxJc3BigB2R6SWAaiXrb4sLj1';
    }
    match /ledger/{doc} {
      allow read, write: if request.auth != null && request.auth.uid == 'uSOqxJc3BigB2R6SWAaiXrb4sLj1';
    }
  }
}
