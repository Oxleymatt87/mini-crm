{
  "hosting": {
    "public": "public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/portal/**",
        "destination": "/portal.html"
      },
      {
        "source": "/map",
        "destination": "/map.html"
      },
      {
        "source": "/test-map",
        "destination": "/test-map.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}
